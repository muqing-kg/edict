{
  "agents": {
    "defaults": {
      "model": {
        "primary": "anthropic/claude-sonnet-4-6"
      }
    },
    "list": [
      {"id": "main", "workspace": "/app/.openclaw/workspace", "subagents": {"allowAgents": ["xingshu"]}},
      {"id": "xingshu", "workspace": "/app/.openclaw/workspace-xingshu", "subagents": {"allowAgents": ["lengjing", "zhongji"]}},
      {"id": "lengjing", "workspace": "/app/.openclaw/workspace-lengjing", "subagents": {"allowAgents": ["zhongji", "xingshu"]}},
      {"id": "zhongji", "workspace": "/app/.openclaw/workspace-zhongji", "subagents": {"allowAgents": ["xingshu", "lengjing", "yuanliu", "wenshu", "weikong", "tanzhen", "jiwu", "xulie"]}},
      {"id": "yuanliu", "workspace": "/app/.openclaw/workspace-yuanliu", "subagents": {"allowAgents": ["zhongji"]}},
      {"id": "wenshu", "workspace": "/app/.openclaw/workspace-wenshu", "subagents": {"allowAgents": ["zhongji"]}},
      {"id": "weikong", "workspace": "/app/.openclaw/workspace-weikong", "subagents": {"allowAgents": ["zhongji"]}},
      {"id": "tanzhen", "workspace": "/app/.openclaw/workspace-tanzhen", "subagents": {"allowAgents": ["zhongji"]}},
      {"id": "jiwu", "workspace": "/app/.openclaw/workspace-jiwu", "subagents": {"allowAgents": ["zhongji"]}},
      {"id": "xulie", "workspace": "/app/.openclaw/workspace-xulie", "subagents": {"allowAgents": ["zhongji"]}},
      {"id": "tianyan", "workspace": "/app/.openclaw/workspace-tianyan", "subagents": {"allowAgents": []}}
    ]
  },
  "providers": {}
}
